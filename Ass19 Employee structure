#include <stdio.h>
#include <string.h>

struct employee {
    char name[50];
    char designation[50];
    char gender[10];
    char doj[15];
    float salary;
};

void countEmployees(struct employee e[], int n);
void countGender(struct employee e[], int n);
void highSalary(struct employee e[], int n);
void asstManager(struct employee e[], int n);

int main() {
    struct employee e[100];
    int n, i;

    printf("Enter number of employees: ");
    scanf("%d", &n);
    getchar(); // ← NEW: buffer clear karo

    for(i = 0; i < n; i++) {
        printf("\nEnter details of employee %d:\n", i + 1);

        printf("Name: ");
        fgets(e[i].name, sizeof(e[i].name), stdin);          // ← FIXED
        e[i].name[strcspn(e[i].name, "\n")] = '\0';

        printf("Designation: ");
        fgets(e[i].designation, sizeof(e[i].designation), stdin); // ← FIXED
        e[i].designation[strcspn(e[i].designation, "\n")] = '\0';

        printf("Gender (Male/Female): ");
        fgets(e[i].gender, sizeof(e[i].gender), stdin);      // ← FIXED
        e[i].gender[strcspn(e[i].gender, "\n")] = '\0';

        printf("Date of Joining (dd-mm-yyyy): ");
        fgets(e[i].doj, sizeof(e[i].doj), stdin);            // ← FIXED
        e[i].doj[strcspn(e[i].doj, "\n")] = '\0';

        printf("Salary: ");
        scanf("%f", &e[i].salary);
        getchar(); // ← NEW: next iteration ke liye buffer clear
    }

    countEmployees(e, n);
    countGender(e, n);
    highSalary(e, n);
    asstManager(e, n);

    return 0;
}

void countEmployees(struct employee e[], int n) {
    printf("\nTotal number of employees = %d\n", n);
}

void countGender(struct employee e[], int n) {
    int male = 0, female = 0, i;

    for(i = 0; i < n; i++) {
        if(strcmp(e[i].gender, "Male") == 0)
            male++;
        else if(strcmp(e[i].gender, "Female") == 0)
            female++;
    }

    printf("Male employees = %d\n", male);
    printf("Female employees = %d\n", female);
}

void highSalary(struct employee e[], int n) {
    int i;
    printf("\nEmployees with salary > 10000:\n");

    for(i = 0; i < n; i++) {
        if(e[i].salary > 10000) {
            printf("%s\n", e[i].name);
        }
    }
}

void asstManager(struct employee e[], int n) {
    int i;
    printf("\nEmployees with designation 'Asst Manager':\n");

    for(i = 0; i < n; i++) {
        if(strcmp(e[i].designation, "Asst Manager") == 0) {
            printf("%s\n", e[i].name);
        }
    }
}
