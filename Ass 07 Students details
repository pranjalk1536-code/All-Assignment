#include <stdio.h>

struct student {
    int roll_no;
    char name[50];
    float m1, m2, m3;
    float total;
    float average;
};

int main() {
    int n;
    
    printf("Enter number of students: ");
    scanf("%d", &n);
    
    struct student s[n];
    
    // Step 4: Input data for each student
    for (int i = 0; i < n; i++) {
        printf("\nEnter details for student %d:\n", i + 1);
        
        printf("Roll Number: ");
        scanf("%d", &s[i].roll_no);
        
        printf("Name: ");
        scanf("%s", s[i].name);
        
        printf("Enter marks of 3 subjects:\n");
        printf("Subject 1: ");
        scanf("%f", &s[i].m1);
        printf("Subject 2: ");
        scanf("%f", &s[i].m2);
        printf("Subject 3: ");
        scanf("%f", &s[i].m3);
        
        // Calculate total and average
        s[i].total   = s[i].m1 + s[i].m2 + s[i].m3;
        s[i].average = s[i].total / 3;
    }
    
    // Step 5: Display results
    printf("\n%-10s %-15s %-10s %-10s %-10s\n",
           "Roll No", "Name", "Total", "Average", "Result");
    printf("------------------------------------------------------------\n");
    
    for (int i = 0; i < n; i++) {
        printf("%-10d %-15s %-10.2f %-10.2f",
               s[i].roll_no, s[i].name, s[i].total, s[i].average);
        
        if (s[i].average >= 40)
            printf("Pass\n");
        else
            printf("Fail\n");
    }
    
    return 0;
}
