#include <stdio.h>
#include <math.h>

// function to calculate factorial
int fact(int n) {
    int i, f = 1;
    for(i = 1; i <= n; i++)
        f *= i;
    return f;
}

int main() {
    int n, i, sign = 1;
    float x, sum = 0;

    printf("Enter value of x (in radians): ");
    scanf("%f", &x);

    printf("Enter number of terms: ");
    scanf("%d", &n);

    for(i = 1; i <= n; i++) {
        sum += sign * pow(x, (2*i - 1)) / fact(2*i - 1);
        sign = -sign;   // alternate + and -
    }

    printf("Sum of sine series = %.4f\n", sum);

    return 0;
}
