#include <stdio.h>

int main() {
    int marks[5];
    int i;
    int total = 0;
    float percentage;
    int isPass = 1;

    // Input marks
    printf("Enter marks of 5 courses:\n");
    for(i = 0; i < 5; i++) {
        scanf("%d", &marks[i]);

        if(marks[i] < 40) {
            isPass = 0;  // Fail condition
        }

        total += marks[i];
    }

    // Check result
    if(isPass == 0) {
        printf("Result: FAIL\n");
    } else {
        percentage = total / 5.0;

        printf("Result: PASS\n");
        printf("Aggregate Percentage = %.2f%%\n", percentage);

        // Grade assignment
        if(percentage >= 75)
            printf("Grade: Distinction\n");
        else if(percentage >= 60)
            printf("Grade: First Class\n");
        else if(percentage >= 50)
            printf("Grade: Second Class\n");
        else
            printf("Grade: Pass Class\n");
    }

    return 0;
}
