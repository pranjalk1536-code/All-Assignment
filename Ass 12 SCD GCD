#include <stdio.h>

int main() {
    int a, b, i;
    int gcd = 1, scd = 0;

    printf("Enter two numbers: ");
    scanf("%d %d", &a, &b);

    // Loop to find GCD and SCD
    for(i = 1; i <= a && i <= b; i++) {
        if(a % i == 0 && b % i == 0) {
            if(scd == 0) {
                scd = i;   // first common divisor = smallest
            }
            gcd = i;       // keeps updating → last = greatest
        }
    }

    printf("Smallest Common Divisor (SCD) = %d\n", scd);
    printf("Greatest Common Divisor (GCD) = %d\n", gcd);

    return 0;
}
