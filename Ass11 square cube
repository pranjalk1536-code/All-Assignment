#include <stdio.h>
#include <math.h>

// Function to check prime
int isPrime(int n) {
    int i;
    if(n <= 1)
        return 0;
    for(i = 2; i <= n/2; i++) {
        if(n % i == 0)
            return 0;
    }
    return 1;
}

// Function to calculate factorial
long int factorial(int n) {
    long int fact = 1;
    int i;
    for(i = 1; i <= n; i++) {
        fact *= i;
    }
    return fact;
}

// Function to print prime factors
void primeFactors(int n) {
    int i;
    printf("Prime factors: ");
    for(i = 2; i <= n; i++) {
        while(n % i == 0) {
            printf("%d ", i);
            n = n / i;
        }
    }
    printf("\n");
}

int main() {
    int num;
    double sqrt_val;

    printf("Enter a number: ");
    scanf("%d", &num);

    // Square root
    if(num >= 0) {
        sqrt_val = sqrt(num);
        printf("Square root = %.2lf\n", sqrt_val);
    } else {
        printf("Square root not defined for negative numbers\n");
    }

    // Square and cube
    printf("Square = %d\n", num * num);
    printf("Cube = %d\n", num * num * num);

    // Prime check
    if(isPrime(num))
        printf("Number is Prime\n");
    else
        printf("Number is NOT Prime\n");

    // Factorial
    if(num >= 0)
        printf("Factorial = %ld\n", factorial(num));
    else
        printf("Factorial not defined for negative numbers\n");

    // Prime factors
    if(num > 1)
        primeFactors(num);
    else
        printf("Prime factors not applicable\n");

    return 0;
}
