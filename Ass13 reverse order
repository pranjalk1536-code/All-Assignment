#include <stdio.h>

int main() {
    int num, digit;

    printf("Enter a number: ");
    scanf("%d", &num);

    printf("Reversed digits: ");

    while(num != 0) {
        digit = num % 10;      // get last digit
        printf("%d", digit);   // print it
        num = num / 10;        // remove last digit
    }

    return 0;
}
