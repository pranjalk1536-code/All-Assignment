#include <stdio.h>

// Function without recursion (loop)
int fact_loop(int n) {
    int i, fact = 1;
    for(i = 1; i <= n; i++) {
        fact *= i;
    }
    return fact;
}

// Function with recursion
int fact_rec(int n) {
    if(n == 0 || n == 1)
        return 1;
    else
        return n * fact_rec(n - 1);
}

int main() {
    int num;

    printf("Enter a number: ");
    scanf("%d", &num);

    if(num < 0) {
        printf("Factorial not defined for negative numbers.\n");
    } else {
        printf("Factorial (Without Recursion) = %d\n", fact_loop(num));
        printf("Factorial (With Recursion) = %d\n", fact_rec(num));
    }

    return 0;
}
